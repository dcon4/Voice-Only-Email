<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".VoiceGmailApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VoiceGmail">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!--
                OAuth redirect intent-filter on MainActivity (singleTask) so that:
                  - When the process is alive, onNewIntent() fires on the existing instance.
                  - When the process was killed while Chrome was open, Android starts a fresh
                    MainActivity and calls onCreate() with the redirect URI in intent.data.
                This completely bypasses AppAuth's AuthorizationManagementActivity result
                delivery, which silently drops the auth code when the app process has died.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="${appAuthRedirectScheme}" />
            </intent-filter>
        </activity>

        <!--
            Disable AppAuth's built-in RedirectUriReceiverActivity.
            We intercept the redirect in MainActivity directly (see intent-filter above).
            Empty declaration (tools:node="replace", no intent-filter) stops the library
            component from competing for the redirect URI.
        -->
        <activity
            android:name="net.openid.appauth.RedirectUriReceiverActivity"
            android:exported="true"
            tools:node="replace" />

    </application>

</manifest>
